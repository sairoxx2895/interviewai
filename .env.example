GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides
GEMINI_MODEL=gemini-1.5-flash
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_DEBUG=True
PORT=5000
